# ===== 진로톡(CareerTalk) MCP 서버 환경변수 =====

# --- 사람인 OpenAPI ---
# https://oapi.saramin.co.kr/ 에서 회원가입 후 access-key 발급
SARAMIN_ACCESS_KEY=

# --- 온통청년 OpenAPI ---
# https://www.data.go.kr/data/15143273/openapi.do 에서 활용신청 후 openApiVlak 발급
YOUTH_OPEN_API_KEY=

# --- LLM API ---
# OpenAI API 키 (진로 분석·자소서 첨삭에 사용)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- 서버 설정 (선택) ---
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8001

# --- Mock 모드 ---
# true 로 설정 시 외부 API 호출 없이 샘플 데이터 반환 (개발/데모용)
MOCK_MODE=false

# --- 응답 캐시 (선택) ---
# 동일 입력 재요청 시 외부 API·LLM 재호출 없이 즉시 반환 (Mock 모드에선 자동 비활성).
RESPONSE_CACHE_ENABLED=true
JOBS_CACHE_TTL=600        # 사람인 채용공고 결과 캐시 (초) — 일일 500회 한도 보호
YOUTH_CACHE_TTL=600       # 온통청년 정책 결과 캐시 (초)
LLM_CACHE_TTL=3600        # LLM(진로분석·자소서첨삭) 결과 캐시 (초)

# --- LLM 호출 안정성 (선택) ---
LLM_TIMEOUT_SECONDS=30    # LLM 호출 타임아웃 (초). 초과 시 Mock 폴백.

# --- 레이트리밋 (선택, 공개 배포 방어) ---
# 프로세스 전역 분당 호출 제한. Mock 모드에선 자동 비활성.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30      # 외부 API(사람인·온통청년) 분당 한도
LLM_RATE_LIMIT_PER_MINUTE=10  # LLM(진로분석·자소서첨삭) 분당 한도

# --- 로깅 (선택) ---
LOG_LEVEL=INFO            # LLM 폴백·API 오류·레이트리밋은 WARNING 으로 기록

# --- 온통청년 API 엔드포인트 (선택) ---
# 기본은 현행 v2(getPlcy, 인증키 apiKeyNm). 발급키가 구버전이면 아래 legacy 로 교체:
#   https://www.youthcenter.go.kr/opi/youthPlcyList.do   (인증키 openApiVlak)
YOUTH_API_ENDPOINT=https://www.youthcenter.go.kr/go/ythip/getPlcy
# 나이·지역·상황 후처리 필터로 결과가 줄면 display 를 채울 때까지 이어서 가져올 최대 페이지 수
YOUTH_MAX_FETCH_PAGES=3