# ===== 진로톡(CareerTalk) MCP 서버 환경변수 =====

# --- 사람인 OpenAPI ---
# https://oapi.saramin.co.kr/ 에서 회원가입 후 access-key 발급
SARAMIN_ACCESS_KEY=

# --- 온통청년 OpenAPI ---
# https://www.data.go.kr/data/15143273/openapi.do 에서 활용신청 후 openApiVlak 발급
YOUTH_OPEN_API_KEY=

# --- LLM API ---
# OpenAI API 키 (진로 분석·자소서 첨삭에 사용)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- 서버 설정 (선택) ---
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8001

# --- Mock 모드 ---
# 공개 배포 기본값은 키를 사용하지 않는 안전 모드입니다.
MOCK_MODE=true
# 실제 외부 API 호출은 MOCK_MODE=false와 아래 값을 모두 명시해야 합니다.
LIVE_API_ENABLED=false

# --- 응답 캐시 (선택) ---
# 동일 입력 재요청 시 외부 API·LLM 재호출 없이 즉시 반환 (Mock 모드에선 자동 비활성).
RESPONSE_CACHE_ENABLED=true
JOBS_CACHE_TTL=600        # 사람인 채용공고 결과 캐시 (초) — 일일 500회 한도 보호
YOUTH_CACHE_TTL=600       # 온통청년 정책 결과 캐시 (초)
LLM_CACHE_TTL=3600        # LLM(진로분석·자소서첨삭) 결과 캐시 (초)

# --- LLM 호출 안정성 (선택) ---
LLM_TIMEOUT_SECONDS=2.2
EXTERNAL_API_TIMEOUT_SECONDS=2.2
OPENAI_MAX_OUTPUT_TOKENS=1200

# --- 영속 일일 쿼터·동시 호출 제한 ---
DAILY_QUOTA_ENABLED=true
USAGE_DB_PATH=data/usage.db
SARAMIN_DAILY_LIMIT=400
YOUTH_DAILY_LIMIT=300
OPENAI_DAILY_LIMIT=100
EXTERNAL_API_MAX_CONCURRENCY=4
OPENAI_MAX_CONCURRENCY=2

# --- 레이트리밋 (선택, 공개 배포 방어) ---
# 프로세스 전역 분당 호출 제한. Mock 모드에선 자동 비활성.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30      # 외부 API(사람인·온통청년) 분당 한도
LLM_RATE_LIMIT_PER_MINUTE=10  # LLM(진로분석·자소서첨삭) 분당 한도

# --- 로깅 (선택) ---
LOG_LEVEL=INFO            # LLM 폴백·API 오류·레이트리밋은 WARNING 으로 기록

# --- 온통청년 API 엔드포인트 (선택) ---
# 온통청년 공식 공개 문서의 요청 URL (인증키 openApiVlak)
# 대체 getPlcy/apiKeyNm 형식을 쓰는 별도 키를 받은 경우에만 이 값을 변경하세요.
YOUTH_API_ENDPOINT=https://www.youthcenter.go.kr/opi/youthPlcyList.do
# 나이·지역·상황 후처리 필터로 결과가 줄면 display 를 채울 때까지 이어서 가져올 최대 페이지 수
YOUTH_MAX_FETCH_PAGES=3
